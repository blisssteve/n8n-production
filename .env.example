# n8n Production Environment Variables
# Copy this file to .env and fill in the values
# Dokploy will manage secrets in its Environment tab

# ============================================
# REQUIRED - Database
# ============================================
POSTGRES_USER=n8n
POSTGRES_PASSWORD=<generate-strong-password>
POSTGRES_DB=n8n

# ============================================
# REQUIRED - Encryption
# ============================================
# MUST match the source instance encryption key for migration
# Source key is in /opt/n8n/config on vultr1
N8N_ENCRYPTION_KEY=<from-source-instance>

# ============================================
# REQUIRED - Task Runners Auth
# ============================================
# Generate a random token for task runner authentication
N8N_RUNNERS_AUTH_TOKEN=<generate-random-token>

# ============================================
# OPTIONAL - Hostname and URLs
# ============================================
# Defaults to n8n.emerald.vet
N8N_HOST=n8n.emerald.vet
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.emerald.vet/

# ============================================
# OPTIONAL - Timezone
# ============================================
TZ=Australia/Brisbane
GENERIC_TIMEZONE=Australia/Brisbane

# ============================================
# OPTIONAL - Resource Limits
# ============================================
# Node.js heap size in MB
NODE_MEMORY=4096
# Max payload size in MB
N8N_PAYLOAD_SIZE_MAX=10240
# Postgres connection pool size
DB_POSTGRESDB_POOL_SIZE=10

# ============================================
# OPTIONAL - Execution Pruning
# ============================================
# Days to keep execution data
EXECUTIONS_DATA_MAX_AGE=7
# Max number of executions to keep
EXECUTIONS_DATA_PRUNE_MAX_COUNT=1000

# ============================================
# OPTIONAL - n8n Port
# ============================================
# Only change if you need a different host port
N8N_PORT=5678
